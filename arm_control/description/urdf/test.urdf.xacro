<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="test">

  <xacro:include filename="$(find arm_control)/description/ros2_control/hardware_ros2_control.xacro"/>
  
  <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
  <material name="blue"><color rgba="0.1 0.1 0.8 1"/></material>
  <material name="red"><color rgba="0.8 0.1 0.1 1"/></material>

  <link name="base_link">
    <visual>
      <geometry><box size="0.2 0.2 0.1"/></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <link name="odrive_link_1">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><box size="0.1 0.1 0.3"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  
  <link name="odrive_link_2">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><box size="0.1 0.1 0.3"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  
  <link name="odrive_link_3">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><box size="0.1 0.1 0.3"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <link name="servo_link_1">
    <visual>
      <geometry><cylinder length="0.06" radius="0.02"/></geometry>
      <material name="red"/>
    </visual>
  </link>
  
  <link name="servo_link_2">
    <visual>
      <geometry><cylinder length="0.06" radius="0.02"/></geometry>
      <material name="red"/>
    </visual>
  </link>
  
  <link name="gripper_link">
      <visual>
          <geometry><box size="0.02 0.1 0.02"/></geometry>
          <origin xyz="0 0 0.05" rpy="0 0 0"/>
          <material name="grey"/>
      </visual>
      <collision>
          <geometry><box size="0.02 0.1 0.02"/></geometry>
          <origin xyz="0 0 0.05" rpy="0 0 0"/>
      </collision>
  </link>
  
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="odrive_link_1"/>
    <origin xyz="0 -0.1 0.1"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" lower="-3.12" upper="3.12" velocity="1"/>  
  </joint>
  
  <joint name="joint2" type="revolute">
    <parent link="odrive_link_1"/>
    <child link="odrive_link_2"/>
    <origin xyz="0 0 0.3"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" lower="-1.05" upper="1.92" velocity="1"/>  
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="odrive_link_2"/>
    <child link="odrive_link_3"/>
    <origin xyz="0 0 0.3"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" lower="-2.27" upper="2.27" velocity="1"/>  
  </joint>
  
  <joint name="joint4" type="revolute">
    <parent link="base_link"/>
    <child link="servo_link_1"/>
    <origin xyz="0 0.1 0.1"/>
    <axis xyz="0 0 1"/>
    <limit effort="1" lower="-2.09" upper="2.09" velocity="1"/> 
  </joint>
  
  <joint name="joint5" type="revolute">
    <parent link="servo_link_1"/>
    <child link="servo_link_2"/>
    <origin xyz="0 0 0.1"/>
    <axis xyz="0 1 0"/>
    <limit effort="1" lower="-2.09" upper="2.09" velocity="1"/>  
  </joint>
  
  <joint name="gripper1" type="revolute">
      <parent link="servo_link_2"/>
      <child link="gripper_link"/>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.3" upper="0.3" effort="1" velocity="1"/>
  </joint>

  <xacro:arm_control/>
</robot>