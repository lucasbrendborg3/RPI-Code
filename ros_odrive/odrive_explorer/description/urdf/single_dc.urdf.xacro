<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="single_dc_test_robot">

    <!-- Include the ros2_control definition -->
    <xacro:include filename="$(find odrive_explorer)/description/ros2_control/single_dc.ros2_control.xacro"/>

    <!-- Materials -->
    <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    <material name="red"><color rgba="0.8 0.1 0.1 1"/></material>

    <!-- Base Link -->
    <link name="base_link">
        <visual>
            <geometry><box size="0.05 0.05 0.05"/></geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry><box size="0.05 0.05 0.05"/></geometry>
        </collision>
    </link>

    <!-- Arm Link -->
    <link name="arm_link">
        <visual>
            <geometry><cylinder length="0.06" radius="0.02"/></geometry>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
            <material name="red"/>
        </visual>
        <collision>
            <geometry><cylinder length="0.06" radius="0.02"/></geometry>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
        </collision>
    </link>

    <!-- Revolute Joint (Matches name in ros2_control xacro) -->
    <joint name="revolute_joint" type="revolute">
        <parent link="base_link"/>
        <child link="arm_link"/>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="10" velocity="1.0"/>
    </joint>

    <!-- Instantiate the ros2_control macro -->
    <xacro:single_revolute_ros2_control name="SingleRevoluteSystem" prefix=""/>
</robot>