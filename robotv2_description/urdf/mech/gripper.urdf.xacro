<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:macro name="gripper" params="parent prefix *origin">
    
    <!-- Gripper base link -->
    <link name="gripper_base">
      <inertial>
        <mass value="0.379"/>
        <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <!-- No visual/collision for Pi -->
    </link>

      <!-- Joint: link6 to gripper_base -->
      <joint name="${parent}_to_gripper_base" type="fixed">
          <parent link="${parent}" />
          <child link="gripper_base" />
          <xacro:insert_block name="origin" />
      </joint>


    <!-- Gripper finger right links -->
    <link name="gripper_right1">
      <inertial>
        <mass value="0.0079"/>
        <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    
    <link name="gripper_right2">
      <inertial>
        <mass value="0.025"/>
        <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <link name="gripper_right3">
      <inertial>
        <mass value="0.006"/>
        <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- Gripper finger left links -->
    <link name="gripper_left1">
      <inertial>
        <mass value="0.0079"/>
        <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <link name="gripper_left2">
      <inertial>
        <mass value="0.025"/>
        <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <link name="gripper_left3">
      <inertial>
        <mass value="0.0048"/>
        <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ============ gripper joints =============== -->
    <!-- Gripper controller -->
    <joint name="gripper_controller" type="revolute">
        <origin xyz="0.013125 0.0 0.044" rpy="1.5708 -1.5708 0.0" />
        <parent link="gripper_base" />
        <child link="gripper_right3" />
        <axis xyz="0 0 1" />
        <limit lower="-0.8" upper="0.4" effort="${gripper_effort}" velocity="${gripper_velocity}"/>
     </joint>

    <!-- Joint: Base to Right Link 3 -->
    <joint name="gripper_base_to_gripper_right2" type="revolute">
        <axis xyz="0 0 1" />
        <origin xyz="0.01 0.0 0.066" rpy="1.5708 -1.5708 0.0" />
        <limit lower="-0.5" upper="0.8" effort="${gripper_effort}" velocity="${gripper_velocity}"/>
        <parent link="gripper_base"/>
        <child link="gripper_right2"/>
        <mimic joint="gripper_controller" multiplier="1.0" offset="0"/>
    </joint>

    <!-- Joint: Right Link 3 to Right Link 1 -->
    <joint name="gripper_right3_to_gripper_right1" type="fixed">
        <axis xyz="0 0 1" />
        <origin xyz="0.0 -0.021 0.0" rpy="0 0 0" />
        <parent link="gripper_right3" />
        <child link="gripper_right1" />
    </joint>

    <!-- Joint: Base to Left Link 3 -->
    <joint name="gripper_base_to_gripper_left3" type="revolute">
        <axis xyz="0 0 -1" />
        <limit effort="${gripper_effort}" lower="-0.15" upper="0.7" velocity="${gripper_velocity}" />
        <origin xyz="-0.013125 0.0 0.044" rpy="1.5708 0.0 0.0" />
        <parent link="gripper_base" />
        <child link="gripper_left3" />
        <mimic joint="gripper_controller" multiplier="1.0" offset="0" />
        <dynamics damping="${gripper_damping}" friction="${gripper_friction}" />
    </joint>

    <!-- Joint: Base to Left Link 2 -->
    <joint name="gripper_base_to_gripper_left2" type="revolute">
        <axis xyz="0 0 -1" />
        <limit effort="${gripper_effort}" lower="-0.5" upper="0.8" velocity="${gripper_velocity}" />
        <origin xyz="-0.01 0 0.066" rpy="1.5708 0.0 0.0" />
        <parent link="gripper_base" />
        <child link="gripper_left2" />
        <mimic joint="gripper_controller" multiplier="1.0" offset="0" />
        <dynamics damping="${gripper_damping}" friction="${gripper_friction}" />
    </joint>

    <!-- Joint: Left Link 3 to Left Link 1 -->
    <joint name="gripper_left3_to_gripper_left1" type="fixed">
        <axis xyz="0 0 1" />
        <origin xyz="-0.021 0.0 0.0" rpy="0 0 0" />
        <parent link="gripper_left3" />
        <child link="gripper_left1" />
    </joint>
        
  


  </xacro:macro>

</robot>